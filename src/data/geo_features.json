{
  "_meta": {
    "description": "Feature store geoespacial versionado por location_uuid. Cada ubicación mantiene una lista de snapshots ordenados por valid_from. valid_to=null indica el snapshot activo. Poblado vía Esri (Network Analysis, Business Analyst, POI routing, spatial join censal). El motor ML hace un join temporal durante training (cada fila histórica recibe el snapshot válido en su fecha) y usa el snapshot activo para predicción.",
    "bloques": {
      "isocrona": "Bloque 1 — Isócronas peatonales (Esri Network Analysis): población dentro del área de captación real a 5/10/15 min a pie.",
      "densidad": "Bloque 2 — Densidad comercial y movilidad (Business Analyst / Heat Map): índice normalizado de concentración retail e índice de movilidad peatonal.",
      "pois": "Bloque 3 — POIs y nodos de transporte (Esri routing + POI layer): distancia al transporte más cercano, número y distancia a competidores directos.",
      "sociodemografico": "Macro — Spatial join punto-en-polígono con capas censales (INE/INEGI por CP): renta media y población total del polígono zonal."
    },
    "schema": {
      "valid_from": "Fecha ISO 8601 desde la que este snapshot es válido (inclusive)",
      "valid_to": "Fecha ISO 8601 hasta la que este snapshot es válido (inclusive). null = snapshot activo sin cierre.",
      "poblacion_5min": "Población residente en isocrona peatonal de 5 minutos (personas)",
      "poblacion_10min": "Población residente en isocrona peatonal de 10 minutos (personas)",
      "poblacion_15min": "Población residente en isocrona peatonal de 15 minutos (personas)",
      "densidad_comercial_score": "Índice normalizado [0.0 - 1.0] de concentración retail en isocrona de 10 min",
      "indice_movilidad_peatonal": "Índice de movilidad peatonal [0.0 - 1.0] derivado de matriz de calor Esri",
      "dist_transporte_min_m": "Distancia en metros al nodo de transporte público más cercano (metro, bus, tren)",
      "n_competidores_500m": "Número de competidores directos en radio de 500 metros",
      "dist_competidor_cercano_m": "Distancia en metros al competidor directo más cercano",
      "renta_media_cp": "Renta neta media anual del hogar por código postal fuente INE/INEGI (€ o moneda local)",
      "poblacion_cp": "Población total empadronada en el polígono de CP asignado por spatial join"
    }
  },
